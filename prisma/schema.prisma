// SQLite não suporta enums. Usamos String + constantes em src/lib/enums.ts.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String        @id @default(cuid())
  email     String        @unique
  name      String
  role      String        @default("PARENT")
  familyId  String?
  family    Family?       @relation(fields: [familyId], references: [id])
  phone     String?
  photoPath String?
  cards     PaymentCard[]
  createdAt DateTime      @default(now())
}

model PaymentCard {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  brand       String   // VISA | MASTERCARD | ELO | AMEX | HIPERCARD
  last4       String
  holderName  String
  expiryMonth Int
  expiryYear  Int
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Family {
  id            String              @id @default(cuid())
  name          String
  balanceCents  Int                 @default(0)
  parents       User[]
  children      Child[]
  rewards       Reward[]
  transactions  WalletTransaction[]
  consent       ConsentRecord?
  createdAt     DateTime            @default(now())
}

model Child {
  id           String        @id @default(cuid())
  familyId     String
  family       Family        @relation(fields: [familyId], references: [id])
  displayName  String
  birthDate    DateTime
  interests    String
  avatarSeed   String        @default("default")
  missions     Mission[]
  logs         MissionLog[]
  xpEvents     XpEvent[]
  streak       Streak?
  redemptions  Redemption[]
  achievements Achievement[]
  bosses       MonthlyBoss[]
  highestLevelClaimed Int    @default(1)
  bonusCoins   Int           @default(0)
  createdAt    DateTime      @default(now())
}

model Mission {
  id              String       @id @default(cuid())
  childId         String
  child           Child        @relation(fields: [childId], references: [id])
  title           String
  category        String
  difficulty      String       @default("COMMON")
  xpReward        Int          @default(10)
  rewardText      String?
  rewardId        String?
  reward          Reward?      @relation(fields: [rewardId], references: [id])
  frequency       String       @default("DAILY")
  targetCount     Int          @default(1)
  currentProgress Int          @default(0)
  active          Boolean      @default(true)
  createdById     String
  logs            MissionLog[]
  createdAt       DateTime     @default(now())
}

model MissionLog {
  id         String    @id @default(cuid())
  missionId  String
  mission    Mission   @relation(fields: [missionId], references: [id])
  childId    String
  child      Child     @relation(fields: [childId], references: [id])
  markedAt   DateTime  @default(now())
  photoPath  String?
  childNote  String?
  status     String    @default("PENDING")
  approvedAt DateTime?
  approvedBy String?
  xpAwarded  Int       @default(0)
}

model XpEvent {
  id        String   @id @default(cuid())
  childId   String
  child     Child    @relation(fields: [childId], references: [id])
  amount    Int
  reason    String
  createdAt DateTime @default(now())
}

model Streak {
  id                   String    @id @default(cuid())
  childId              String    @unique
  child                Child     @relation(fields: [childId], references: [id])
  currentDays          Int       @default(0)
  longestDays          Int       @default(0)
  lastActiveDate       DateTime?
  freezesAvailable     Int       @default(2)
  freezesUsedThisMonth Int       @default(0)
}

// --- Recompensas ---

model Reward {
  id           String       @id @default(cuid())
  familyId     String
  family       Family       @relation(fields: [familyId], references: [id])
  title        String
  description  String?
  emoji        String       @default("🎁")
  kind         String       @default("PRIVILEGE") // DIGITAL_CODE | PHYSICAL | EXPERIENCE | PRIVILEGE
  provider     String?      // Roblox | Steam | Spotify | Kindle | iFood | null
  coinsCost    Int
  costCents    Int          @default(0) // 0 = não custa dinheiro (vale offline/privilégio)
  originalCostCents Int     @default(0) // se > costCents, mostra desconto
  minLevel     Int          @default(0) // 0 = sem trava; >0 = exige child.level >= minLevel
  stock        Int          @default(0) // quantidade comprada pelo pai, ainda não vinculada a missão
  active       Boolean      @default(true)
  featured     Boolean      @default(false)
  forBoss      Boolean      @default(false) // recompensas especiais usadas apenas como drop de boss mensal
  redemptions  Redemption[]
  missions     Mission[]
  bossDrops    MonthlyBoss[]
}

model Redemption {
  id            String    @id @default(cuid())
  childId       String
  child         Child     @relation(fields: [childId], references: [id])
  rewardId      String
  reward        Reward    @relation(fields: [rewardId], references: [id])
  requestedAt   DateTime  @default(now())
  status        String    @default("REQUESTED") // REQUESTED | APPROVED | DELIVERED | REJECTED
  coinsSpent    Int       @default(0)
  costCentsPaid Int       @default(0)
  deliveredAt   DateTime?
  parentNote    String?
  deliveryCode  String?   // código de gift card / instrução
}

// --- Carteira parental ---

model WalletTransaction {
  id          String   @id @default(cuid())
  familyId    String
  family      Family   @relation(fields: [familyId], references: [id])
  amountCents Int      // positivo = crédito, negativo = débito
  type        String   // CREDIT | DEBIT_REDEMPTION | REFUND
  description String
  createdAt   DateTime @default(now())
}

// --- Conquistas / badges ---

model Achievement {
  id          String   @id @default(cuid())
  childId     String
  child       Child    @relation(fields: [childId], references: [id])
  code        String   // FIRST_MISSION | STREAK_7 | STREAK_30 | TEN_MISSIONS | BOSS_HUNTER | LEVEL_5
  title       String
  emoji       String
  earnedAt    DateTime @default(now())

  @@unique([childId, code])
}

// --- LGPD ---

model ConsentRecord {
  id            String   @id @default(cuid())
  familyId      String   @unique
  family        Family   @relation(fields: [familyId], references: [id])
  parentName    String
  parentDocHash String
  acceptedAt    DateTime @default(now())
  termsVersion  String
}

// --- Boss mensal ---

model BossTemplate {
  id           String        @id @default(cuid())
  month        Int           // 1-12
  year         Int
  name         String
  iconName     String        @default("orcboss")
  defaultMaxHp Int           @default(500)
  createdAt    DateTime      @default(now())
  bosses       MonthlyBoss[]

  @@unique([month, year])
}

model MonthlyBoss {
  id          String        @id @default(cuid())
  childId     String
  child       Child         @relation(fields: [childId], references: [id])
  templateId  String?
  template    BossTemplate? @relation(fields: [templateId], references: [id])
  month       Int           // 1-12
  year        Int           // 2026
  name        String
  iconName    String        @default("orcboss")
  maxHp       Int           @default(500)
  currentHp   Int           @default(500)
  active      Boolean       @default(false)
  rewardId    String?
  reward      Reward?       @relation(fields: [rewardId], references: [id])
  defeatedAt  DateTime?
  createdAt   DateTime      @default(now())
  damageLogs  BossDamage[]

  @@unique([childId, month, year])
}

model BossDamage {
  id           String      @id @default(cuid())
  bossId       String
  boss         MonthlyBoss @relation(fields: [bossId], references: [id])
  missionLogId String      @unique
  amount       Int
  createdAt    DateTime    @default(now())
}
